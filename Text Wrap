#include <stdio.h>

// Check if we can fit in k lines with width W
int canFit(int arr[], int n, int k, int W) {
    int lines = 1;
    int currentWidth = 0;

    for (int i = 0; i < n; i++) {
        if (arr[i] > W) return 0; // single word too big

        if (currentWidth == 0) {
            currentWidth = arr[i];
        } else if (currentWidth + 1 + arr[i] <= W) {
            currentWidth += 1 + arr[i]; // add space + word
        } else {
            lines++;
            currentWidth = arr[i];
        }
    }

    return lines <= k;
}

int main() {
    int n, k;
    scanf("%d %d", &n, &k);

    int arr[n];
    int maxWord = 0, sum = 0;

    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        if (arr[i] > maxWord) maxWord = arr[i];
        sum += arr[i];
    }

    int left = maxWord;
    int right = sum + (n - 1); // include spaces
    int answer = right;

    // Binary Search
    while (left <= right) {
        int mid = (left + right) / 2;

        if (canFit(arr, n, k, mid)) {
            answer = mid;
            right = mid - 1; // try smaller
        } else {
            left = mid + 1;  // need larger
        }
    }

    printf("%d\n", answer);

    return 0;
}
